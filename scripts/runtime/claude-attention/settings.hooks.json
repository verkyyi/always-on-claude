{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/guard.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/set-claude-state.sh busy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/set-claude-state.sh working"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/set-claude-state.sh working"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/set-claude-state.sh needs bell"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/set-claude-state.sh done"
          }
        ]
      }
    ]
  }
}
