# always-on-claude configuration
#
# Copy this file to .env and customize values for your deployment.
# All scripts read from .env — this is the single source of truth.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your preferences
#   bash scripts/deploy/provision.sh    # or /provision
#
# Docker Compose also reads .env automatically for variable substitution.
# Values can still be overridden with environment variables at runtime.

# --- AWS / EC2 ----------------------------------------------------------------

# EC2 instance type (t4g.small = ARM, cheapest; t3.medium = x86, more headroom)
INSTANCE_TYPE=t4g.small

# AWS region (defaults to your AWS CLI region if unset)
# AWS_REGION=us-east-1

# EBS volume size in GB
VOLUME_SIZE=20

# Instance name tag (also used as SSH config Host entry)
INSTANCE_NAME=claude-dev

# SSH key pair name in AWS
KEY_NAME=claude-dev-key

# Security group name
SG_NAME=claude-dev-sg

# SSH username on the instance
SSH_USER=dev

# AWS resource tag for identifying always-on-claude resources
PROJECT_TAG=always-on-claude

# --- Docker -------------------------------------------------------------------

# Container image (multi-arch: amd64 + arm64)
DOCKER_IMAGE=ghcr.io/verkyyi/always-on-claude:latest

# Container name
CONTAINER_NAME=claude-dev

# Container hostname
CONTAINER_HOSTNAME=claude-dev

# --- Paths --------------------------------------------------------------------

# Where the repo is cloned on the server/Mac
DEV_ENV=$HOME/dev-env

# Projects directory (bind-mounted into container)
PROJECTS_DIR=$HOME/projects

# --- Runtime ------------------------------------------------------------------

# Default coding assistant launched from the workspace picker (claude or codex)
DEFAULT_CODE_AGENT=claude

# --- AMI build ----------------------------------------------------------------

# Instance type used for building AMIs (needs more resources than runtime)
AMI_BUILD_INSTANCE_TYPE=t3.medium

# Volume size for AMI builds (minimum for OS + Docker image; instances can use larger volumes)
AMI_BUILD_VOLUME_SIZE=20

# --- Sessions -----------------------------------------------------------------

# Maximum concurrent Claude sessions (0 = auto-detect based on RAM/CPU)
# MAX_SESSIONS=0

# --- Tailscale (optional) -----------------------------------------------------

# Tailscale hostname for private access from anywhere
# TAILSCALE_HOSTNAME=my-dev-server
