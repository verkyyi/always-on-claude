# Dockerfile.portable — Self-contained always-on-claude image.
#
# Extends the base image with Tailscale, cron/at, and all scripts baked in.
# Run with a single `docker run` command — no host setup needed.
#
# Usage:
#   docker run -d --name claude-dev \
#     -v claude-data:/home/dev/.claude \
#     -v claude-projects:/home/dev/projects \
#     ghcr.io/verkyyi/always-on-claude:portable
#
# With Tailscale (remote SSH access):
#   docker run -d --cap-add=NET_ADMIN --name claude-dev \
#     -v claude-data:/home/dev/.claude \
#     -v claude-projects:/home/dev/projects \
#     -v tailscale-state:/var/lib/tailscale \
#     -e TS_AUTHKEY=tskey-auth-xxx \
#     ghcr.io/verkyyi/always-on-claude:portable

FROM ubuntu:24.04

LABEL org.opencontainers.image.source="https://github.com/verkyyi/always-on-claude"
LABEL org.opencontainers.image.description="Always-on Claude Code workspace (portable) — single container, docker run and go"

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/home/dev/.local/bin:${PATH}"

# System packages — ripgrep, fzf, and zsh are required by Claude Code
RUN apt-get update && apt-get install -y \
    curl git tmux vim jq unzip \
    build-essential python3 python3-pip \
    ripgrep fzf zsh \
    cron at \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22.x LTS
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

# AWS CLI v2
RUN curl "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o "awscliv2.zip" \
    && unzip awscliv2.zip && ./aws/install \
    && rm -rf aws awscliv2.zip

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh

# Tailscale — for remote SSH access without exposing ports
RUN curl -fsSL https://tailscale.com/install.sh | sh

# Non-root user (Claude Code refuses to run as root)
RUN userdel -r ubuntu 2>/dev/null || true \
    && groupadd -g 1000 dev && useradd -m -s /bin/bash -u 1000 -g 1000 dev \
    && echo 'dev ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/dev

# Claude Code — native installer, must run as non-root
USER dev
RUN curl -fsSL https://claude.ai/install.sh | bash
USER root

# Pre-create .claude dirs — Docker volumes mount as root and can
# overwrite ownership, causing ENOENT crashes without these
RUN mkdir -p /home/dev/.claude/debug \
    && touch /home/dev/.claude/remote-settings.json \
    && chown -R dev:dev /home/dev/.claude

# Pre-create directories that may be volume-mounted
RUN mkdir -p /home/dev/projects /home/dev/overnight /home/dev/.config/gh \
    && chown -R dev:dev /home/dev/projects /home/dev/overnight /home/dev/.config

# Tailscale state directory
RUN mkdir -p /var/lib/tailscale

# Bun — fast JS runtime/package manager used by many projects
USER dev
WORKDIR /home/dev
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/home/dev/.bun/bin:${PATH}"

# Shell aliases
RUN echo '\n\
alias cc="claude --dangerously-skip-permissions"\n\
alias gs="git status"\n\
alias gl="git log --oneline -20"\n\
' >> /home/dev/.bashrc

# Copy all project files into the image as dev-env
USER root
COPY --chown=dev:dev . /home/dev/dev-env

# Make scripts executable
RUN chmod +x /home/dev/dev-env/scripts/portable/*.sh \
    /home/dev/dev-env/scripts/runtime/*.sh \
    /home/dev/dev-env/scripts/deploy/*.sh 2>/dev/null || true

# Entrypoint runs as root (needs to start system services),
# then the user logs in as dev
ENTRYPOINT ["/home/dev/dev-env/scripts/portable/entrypoint.sh"]
